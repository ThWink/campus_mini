.container { padding: 30rpx; background: #f7f7f7; min-height: 100vh; }
.list-title { font-size: 36rpx; font-weight: bold; margin-bottom: 30rpx; color: #333; }

.empty { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 120rpx; display: block; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: #999; }

.order-item { background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.item-header { display: flex; flex-direction: column; padding-bottom: 20rpx; border-bottom: 1rpx solid #f5f5f5; margin-bottom: 20rpx; }
.order-id-row { display: flex; align-items: center; margin-bottom: 12rpx; }
.order-id-label { font-size: 24rpx; color: #999; }
.order-id-value { font-size: 24rpx; color: #333; font-family: monospace; background: #f5f5f5; padding: 4rpx 12rpx; border-radius: 6rpx; }
.title-row { display: flex; justify-content: space-between; align-items: center; }
.title { font-weight: bold; font-size: 32rpx; color: #333; }
.status-tag { font-size: 24rpx; padding: 6rpx 16rpx; border-radius: 20rpx; }
.s0 { color: #f39c12; background: #fef5e7; }
.s1 { color: #3498db; background: #ebf5fb; }
.s2 { color: #27ae60; background: #eafaf1; }

.item-body { padding: 10rpx 0; }
.row { display: flex; margin-bottom: 16rpx; }
.row .label { font-size: 26rpx; color: #999; min-width: 100rpx; }
.row .value { font-size: 26rpx; color: #666; flex: 1; }
.row .price { color: #fa5151; font-weight: bold; }

.item-footer { padding-top: 20rpx; display: flex; flex-wrap: wrap; align-items: center; gap: 20rpx; }
.btn-group { display: flex; gap: 20rpx; }
.btn-complete, .btn-confirm, .btn-evaluate { 
  font-size: 26rpx !important; 
  padding: 0 32rpx !important; 
  height: 64rpx !important; 
  line-height: 64rpx !important; 
  border-radius: 32rpx !important;
  margin: 0 !important;
}
.btn-complete { background: #07c160; color: white; }
.btn-confirm { background: #07c160; color: white; }
.btn-evaluate { background: #ff9500; color: white; }
.info { font-size: 24rpx; color: #999; width: 100%; padding-top: 10rpx; }
