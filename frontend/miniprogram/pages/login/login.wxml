<view class="login-container">
  <view class="header">
    <text class="title">校园跑腿</text>
    <text class="subtitle">Campus Runner System</text>
  </view>

  <view class="form-box">
    <view class="input-item">
      <text class="label">账号</text>
      <input class="input"
             name="username"
             type="text"
             value="{{username}}"
             placeholder="请输入用户名"
             placeholder-class="placeholder"
             confirm-type="next"
             maxlength="50"
             cursor-spacing="80"
             adjust-position="{{true}}"
             bindinput="onUsernameInput" />
    </view>
    
    <view class="input-item">
      <text class="label">密码</text>
      <input class="input"
             name="password"
             value="{{password}}"
             password="{{true}}"
             placeholder="请输入密码"
             placeholder-class="placeholder"
             confirm-type="done"
             maxlength="100"
             cursor-spacing="80"
             adjust-position="{{true}}"
             bindinput="onPasswordInput"
             bindconfirm="handleLogin" />
    </view>

    <button class="login-btn" bindtap="handleLogin">立即登录</button>
    
    <view class="footer-links">
      <text bindtap="goToRegister">没有账号？去注册</text>
    </view>
  </view>
</view>
