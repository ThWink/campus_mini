<view class="container">
  <view class="order-info">
    <text class="label">订单</text>
    <text class="value">{{orderTitle}}</text>
  </view>

  <view class="order-id-info">
    <text class="label">订单号</text>
    <text class="value">{{orderId}}</text>
  </view>

  <view class="submitted-tip" wx:if="{{submitted}}">
    <text>你已经评价过这个订单</text>
  </view>

  <view class="rating-section">
    <text class="label">服务评分</text>
    <view class="stars">
      <view class="star {{index < rating ? 'active' : ''}}"
            wx:for="{{[1,2,3,4,5]}}"
            wx:key="*this"
            bindtap="onStarTap"
            data-rating="{{item}}">
        ★
      </view>
    </view>
    <text class="rating-text">{{rating}} 星</text>
  </view>

  <view class="content-section">
    <text class="label">评价内容</text>
    <textarea class="textarea"
              disabled="{{submitted}}"
              placeholder="请描述服务是否及时、沟通是否顺畅、任务完成情况"
              maxlength="200"
              bindinput="onContentInput"
              value="{{content}}"></textarea>
  </view>

  <view class="content-section">
    <text class="label">评价标签</text>
    <input class="tag-input"
           disabled="{{submitted}}"
           placeholder="例如：准时、沟通好、服务认真"
           maxlength="50"
           bindinput="onTagsInput"
           value="{{tags}}" />
  </view>

  <button wx:if="{{!submitted}}"
          class="submit-btn"
          loading="{{isSubmitting}}"
          bindtap="submitEvaluate">
    提交评价
  </button>

  <button wx:else class="submit-btn disabled" disabled="{{true}}">
    已评价
  </button>
</view>
