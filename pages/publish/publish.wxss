.container { padding: 30rpx; background-color: #f7f7f7; min-height: 100vh; }
.header-section { margin-bottom: 30rpx; padding-left: 10rpx; }
.page-title { font-size: 44rpx; font-weight: bold; color: #333; }

.form-card { background: #fff; border-radius: 24rpx; padding: 40rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05); }
.form-item { margin-bottom: 36rpx; }
.label { display: block; font-size: 28rpx; color: #666; margin-bottom: 16rpx; font-weight: 500; }
.input-box { height: 96rpx; border-bottom: 1rpx solid #eee; font-size: 32rpx; width: 100%; box-sizing: border-box; }
.input-box:focus { border-bottom-color: #07c160; }

.textarea-box { width: 100%; height: 200rpx; background: #f9f9f9; padding: 24rpx; border-radius: 16rpx; box-sizing: border-box; font-size: 28rpx; line-height: 1.5; }

.submit-btn { 
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%); 
  color: #fff; 
  margin-top: 60rpx; 
  border-radius: 50rpx; 
  font-size: 32rpx; 
  height: 100rpx;
  line-height: 100rpx;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
}
