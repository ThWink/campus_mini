<view class="user-container">
  <view class="user-card">
    <view class="avatar-box">
      <image style="width:100%;height:100%;" src="https://mmbiz.qpic.cn/mmbiz_png/icTdbqWNOwNRna42FI242Lcia07xvMz5QN7p7y8Yk6BscH99Fichic76z9iayk7T1qXvUicY2l7ZibnE0fD9y5I0DViaibA/0?wx_fmt=png"></image>
    </view>
    <view class="user-info">
      <text class="username">{{userInfo.username || '未登录'}}</text>
      <text class="phone">{{userInfo.phone || '点击头像登录'}}</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="navToList" data-type="published">
      <text class="menu-text">📝 我发布的任务</text>
      <text class="arrow">›</text>
    </view>
    
    <view class="menu-item" bindtap="navToList" data-type="accepted">
      <text class="menu-text">🛵 我接取的任务</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="logout-section">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>
</view>