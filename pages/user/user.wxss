.user-container { min-height: 100vh; background-color: #f7f7f7; }

.user-card {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  padding: 60rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
  display: flex;
  align-items: center;
  color: white;
  margin-bottom: 30rpx;
}

.avatar-box {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  margin-right: 30rpx;
  flex-shrink: 0;
}

.user-info { flex: 1; }

.username {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
}

.phone {
  font-size: 26rpx;
  margin-top: 12rpx;
  opacity: 0.9;
  display: block;
}

.menu-list {
  background: white;
  border-radius: 20rpx;
  margin: 0 30rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.menu-item {
  padding: 36rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.2s;
}

.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #f9f9f9; }

.menu-text { font-size: 30rpx; color: #333; }

.arrow { 
  color: #ccc; 
  font-size: 36rpx;
  font-weight: 300;
}

.logout-section { margin: 60rpx 30rpx 0; }
.logout-btn { 
  background-color: #fff; 
  color: #fa5151; 
  border-radius: 40rpx;
  font-size: 30rpx;
  border: 1rpx solid #fa5151;
}
