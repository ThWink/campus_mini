.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.order-info {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.order-info .label, .order-id-info .label {
  font-size: 28rpx;
  color: #666;
}

.order-info .value, .order-id-info .value {
  font-size: 28rpx;
  color: #333;
  margin-left: 10rpx;
}

.order-id-info {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.rating-section {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rating-section .label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.stars {
  display: flex;
  gap: 20rpx;
}

.star {
  font-size: 60rpx;
  color: #ddd;
  transition: color 0.2s;
}

.star.active {
  color: #ffc107;
}

.rating-text {
  font-size: 28rpx;
  color: #ffc107;
  margin-top: 10rpx;
}

.content-section {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
}

.content-section .label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
}

.textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.submit-btn {
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 50rpx;
  height: 100rpx;
  line-height: 100rpx;
}
