CAMPUS_API_BASE=http://127.0.0.1:8080

# Embedding model used by ChromaDB retrieval.
# Preferred generic configuration. SCNet Qwen3 example:
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_BASE_URL=https://api.scnet.cn/api/llm/v1
# EMBEDDING_MODEL=Qwen3-Embedding-8B
# EMBEDDING_BATCH_SIZE=5
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_BATCH_SIZE=

# Provider-specific fallback keys. Keep one of these if you do not use EMBEDDING_API_KEY.
SCNET_API_KEY=
ZHIPUAI_API_KEY=

# Chat model configuration. Fill these when using GLM-compatible OpenAI API.
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-4

# Optional CLI RAG engine configuration.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=

CHROMA_DB_PATH=data/chroma_db
RAG_RAW_DATA_PATH=data/raw/jxau_real_rules.txt
RAG_SEARCH_K=10
RAG_TOP_N=3
RAG_CHUNK_SIZE=200
RAG_CHUNK_OVERLAP=30
BGE_RERANKER_URL=
AGENT_LOG_PATH=logs/agent_events.jsonl
